REDIS_URL="redis://localhost:6379"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:55432/oclushion?schema=public"
VITE_OCLUSHION_CONTROL_API_URL="http://127.0.0.1:8082"
VITE_OPENAI_API_KEY=""
VITE_ANTHROPIC_API_KEY=""
# For key rotation, use format: kid1:base64key,kid2:base64key
# The first key is used for signing; all keys are accepted for verification (rotation grace period).
# Single secret (no colon) works as before.
CONTROL_API_ADMIN_TOKEN="replace-with-at-least-32-random-characters"
CONTROL_API_INTERNAL_TOKEN="replace-with-at-least-32-random-characters"
PROXY_POLICY_ORGANIZATION_IDS=""
POLICY_SNAPSHOT_REFRESH_MS=30000
POLICY_SNAPSHOT_MAX_AGE_MS=120000
# Generate with: openssl rand -base64 32
TOKEN_MAPPING_ENCRYPTION_KEY="replace-with-base64-encoded-32-byte-key"
CONNECTOR_VAULT_ENCRYPTION_KEY="replace-with-base64-encoded-32-byte-key"
TOKEN_MAPPING_TTL_SECONDS=300
PROXY_PORT=8080
PROXY_HOST="0.0.0.0"
PROXY_TIMEOUT_MS=5000
PROXY_ALLOWED_UPSTREAM_HOSTS="api.openai.com,api.anthropic.com"
OPENAI_UPSTREAM_BASE_URL="https://api.openai.com"
ANTHROPIC_UPSTREAM_BASE_URL="https://api.anthropic.com"
ENABLE_AUDIT_LOG=true
ENABLE_RATE_LIMITING=true
PROXY_RATE_LIMIT_MAX=300
CONTROL_API_HOST="127.0.0.1"
CONTROL_API_PORT=8082
CONTROL_API_ENABLE_RATE_LIMITING=true
CONTROL_API_RATE_LIMIT_MAX=120
# JSON array of allowed origins for CORS. Default: localhost ports
CONTROL_API_ALLOWED_ORIGINS='["http://127.0.0.1:1420","http://localhost:1420","tauri://localhost"]'
OCLUSHION_BILLING_PROVIDER="manual"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
OCLUSHION_BILLING_SUCCESS_URL="https://oclushion.com/billing/success"
OCLUSHION_BILLING_CANCEL_URL="https://oclushion.com/billing/cancel"
OCLUSHION_IDENTITY_PROVIDER="local-rbac"
DATA_GATEWAY_HOST="127.0.0.1"
DATA_GATEWAY_PORT=8083
DATA_GATEWAY_TOKEN="replace-with-at-least-32-random-characters"
DATA_SOURCE_DATABASE_URL=""
# Generate with: openssl rand -base64 32
DATA_PROTECT_ENCRYPTION_KEY="replace-with-base64-encoded-32-byte-key"
DATA_GATEWAY_ENABLE_RATE_LIMITING=true
DATA_GATEWAY_RATE_LIMIT_MAX=120
NEXT_PUBLIC_SITE_URL="https://oclushion.com"
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_RELEASE=""
SENTRY_TRACES_SAMPLE_RATE=0.05
# Browser telemetry DSNs are public by design; events are scrubbed before transmission.
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.01

# ============================================
# TAURI UPDATER (CI/CD only — NEVER commit private key)
# Generate with: node scripts/generate-updater-keys.mjs
# ============================================
# TAURI_SIGNING_PRIVATE_KEY=""
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""

# ============================================
# PRODUCTION-ONLY VARIABLES (Wired in compose.yaml)
# These must NOT be defined in .env development files.
# Docker Compose will use :?required syntax to enforce them in production.
# Set these in your CI/CD secret manager (e.g., Vault, GitHub Secrets, AWS Secrets Manager).
# ============================================
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST_PORT=
# REDIS_HOST_PORT=
# CHAT_PROTECT_ENCRYPTION_KEY=
# CHAT_PROTECT_ORGANIZATION_ID=
# CHAT_PROTECT_MOCK_MODE=
# POSTGRES_HOST_PORT=
# REDIS_HOST_PORT=
