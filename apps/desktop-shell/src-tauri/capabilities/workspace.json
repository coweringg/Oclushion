{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "workspace",
  "description": "Per-workspace file permissions for the currently open project",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$APPDATA/oclushion/workspaces/**" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$APPDATA/oclushion/workspaces/**" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APPDATA/oclushion/workspaces/**" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/oclushion/workspaces/**" }, { "path": "$HOME/**" }]
    }
  ]
}
