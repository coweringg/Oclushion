{
  "name": "oclushion-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:release": "pnpm build && pnpm --filter @oclushion/desktop-shell build:native",
    "dev": "turbo run dev",
    "lint": "eslint playwright.config.ts tests && turbo run lint",
    "typecheck": "tsc -p tsconfig.tests.json --noEmit && turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "node tests/e2e/fixtures/preflight.mjs && playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:load": "k6 run tests/load/proxy-sanitization.js",
    "test:zap": "powershell -ExecutionPolicy Bypass -File tests/security/zap-baseline.ps1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "updater:keygen": "node scripts/generate-updater-keys.mjs",
    "updater:sign": "node scripts/sign-release.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "esbuild": "0.28.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "globals": "^16.5.0",
    "pg": "^8.16.3",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}